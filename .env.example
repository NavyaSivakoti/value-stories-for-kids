# Copy this file to .env and fill in your values.
# Never commit the real .env file. It is listed in .gitignore.

# Which model powers the live chatbot: gemini, openai, or anthropic
VALUE_STORIES_PROVIDER=gemini

# API keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model names. Confirm the current names with each provider before deploy.
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5

# Flask session secret. Use any long random string.
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# Optional tuning. Keep MAX_TOKENS generous: some models spend tokens on
# internal "thinking", so a low cap can truncate the story mid-sentence.
VALUE_STORIES_MAX_TOKENS=4000
VALUE_STORIES_TEMPERATURE=0.8
VALUE_STORIES_DAILY_LIMIT=5
